---
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const blogEntries = await getCollection("blog");
  return blogEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{entry.data.title} — Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Space+Mono&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="bg"></div>

  <main>
    <header>
      <div class="header-left">
        <a href={import.meta.env.BASE_URL} class="back-link">← BACK TO HOME</a>
        <span class="badge">{entry.data.category}</span>
        <h1>{entry.data.title}</h1>
        <div class="tech-tags">
          {entry.data.technologies.map(tech => <span class="tech-tag">{tech}</span>)}
        </div>
        <p class="date">{entry.data.date}</p>
      </div>
    </header>

    <article class="content">
      <Content />
    </article>
  </main>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: #f2f0eb;
    color: #1a1a18;
    min-height: 100vh;
    line-height: 1.6;
  }

  .bg {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 64px 24px 80px;
  }

  header {
    margin-bottom: 48px;
    animation: fadeUp .6s ease both;
  }

  .back-link {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #666;
    text-decoration: none;
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .back-link:hover { color: #1a1a18; }

  .badge {
    display: inline-block;
    background: #1a1a18;
    color: #f2f0eb;
    font-family: 'Syne', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: 4px 10px;
    margin-bottom: 16px;
    border-radius: 4px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }

  .tech-tag {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    background: #edeae3;
    color: #444;
    padding: 4px 12px;
    border-radius: 100px;
  }

  .date {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: #888;
  }

  .content {
    background: #fff;
    padding: 48px 40px;
    border-radius: 18px;
    box-shadow: 0 4px 24px rgba(0,0,0,.04);
    animation: fadeUp .6s .15s ease both;
  }

  .content :global(h2) {
    font-size: 24px;
    margin: 32px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid #eee;
  }
  .content :global(h2:first-child) { margin-top: 0; }

  .content :global(p) { margin-bottom: 16px; font-size: 15px; color: #333; }
  .content :global(ul) { margin-bottom: 16px; padding-left: 20px; }
  .content :global(li) { margin-bottom: 8px; font-size: 15px; color: #333; }
  .content :global(a) { color: #2eb87c; text-decoration: none; }
  .content :global(a:hover) { text-decoration: underline; }
  .content :global(video) { border-radius: 8px; margin-top: 16px; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .content { padding: 32px 20px; }
  }
</style>
