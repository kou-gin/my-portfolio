---
import { getCollection } from "astro:content";

const allWorks = await getCollection("blog");
const sortedWorks = allWorks.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const cardColors = ["hero", "green", "yellow"];
const works = sortedWorks.map((post, index) => ({
  id: post.id,
  category: post.data.category,
  title: post.data.title,
  desc: post.data.technologies.join(" / "),
  url: `${import.meta.env.BASE_URL}blog/${post.id}`,
  color: cardColors[index % cardColors.length],
}));

const sns = [
  { name: "X", desc: "日々の発信", url: "#" },
  { name: "Instagram", desc: "ビジュアル", url: "#" },
  { name: "Note", desc: "記事・技術ログ", url: "#" },
  { name: "TikTok", desc: "動画コンテンツ", url: "#" },
  { name: "GitHub", desc: "コードと実績", url: "#" },
];

const skills = ["Python", "Java", "JavaScript", "Power Automate Desktop", "Unity", "GitHub", "VSCode"];
---

<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Portfolio — 高 宗嗣 (Sunsa Kou)</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=Space+Mono&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <div class="bg"></div>

  <main>

    <!-- HEADER -->
    <header>
      <div class="header-left">
        <span class="badge">Engineer & Creator</span>
        <h1>SUNSA KOU / 高 宗嗣</h1>
        <p class="tagline">ITサポート20年 → Python / PAD<br/>技術と成果で価値を出す</p>
      </div>
      <div class="status">
        <span class="dot"></span>
        <span>Available</span>
      </div>
    </header>

    <!-- BENTO WORKS -->
    <section class="bento">

      {works.map((work) => (
        <a href={work.url} class={`card card-${work.color}`}>
          {work.color === "hero" ? (
            <div>
              <span class="card-eyebrow">{work.category}</span>
              <h2 class="card-title">{work.title}</h2>
              <p class="card-desc">{work.desc}</p>
            </div>
          ) : (
            <>
              <span class="card-eyebrow">{work.category}</span>
              <h2 class="card-title">{work.title}</h2>
              <p class="card-desc">{work.desc}</p>
            </>
          )}
          {work.color === "hero" && <span class="arrow">→</span>}
        </a>
      ))}

      <!-- SNS Card -->
      <div class="card card-sns">
        {sns.map(s => (
          <a href={s.url} class="sns-item" target="_blank">
            <span class="sns-name">{s.name}</span>
            <span class="sns-desc">{s.desc}</span>
          </a>
        ))}
      </div>

      <!-- Skills Card -->
      <div class="card card-skills">
        <span class="card-eyebrow">SKILLS</span>
        <div class="skill-tags">
          {skills.map(s => <span class="skill-tag">{s}</span>)}
        </div>
      </div>

    </section>

    <footer>
      <span>© 2026 Sunsa Kou</span>
      <a href="https://github.com/YOUR-USERNAME" target="_blank">GitHub →</a>
    </footer>

  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: #f2f0eb;
    color: #1a1a18;
    min-height: 100vh;
  }

  /* 背景テクスチャ */
  .bg {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 24px 40px;
  }

  /* HEADER */
  header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 36px;
    animation: fadeUp .6s ease both;
  }

  .badge {
    display: inline-block;
    background: #1a1a18;
    color: #f2f0eb;
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: 3px 9px;
    margin-bottom: 12px;
  }

  h1 {
  /* 'Syne' を外し、標準的で美しい 'Inter' や 'sans-serif' を指定 */
  font-family: 'Inter', 'Noto Sans JP', sans-serif; 
  
  /* 横長感を消すため、文字の間隔を「詰め」から「わずかに広め」に（0.02em?0.05em） */
  letter-spacing: 0.02em; 
  
  /* 文字の太さを 800(極太) から 700(太字) にしてスッキリさせる */
  font-weight: 700;
  
  font-size: clamp(32px, 6vw, 48px);
  line-height: 1.1;
  color: #1a1a18;
  margin-bottom: 12px;
  
  /* もし文字が横に引き伸ばされている設定(transform)があれば無効化 */
  transform: none; 
}

  .tagline {
    font-size: 13px;
    line-height: 1.7;
    color: #666;
    font-weight: 300;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #666;
    white-space: nowrap;
    margin-top: 6px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2eb87c;
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(46,184,124,.4); }
    50% { box-shadow: 0 0 0 6px rgba(46,184,124,0); }
  }

  /* BENTO */
  .bento {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    animation: fadeUp .6s .15s ease both;
  }

  /* カード共通 */
  .card {
    border-radius: 18px;
    padding: 24px 22px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .25s cubic-bezier(.4,0,.2,1), box-shadow .25s cubic-bezier(.4,0,.2,1);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,.1);
  }

  .card-eyebrow {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: .15em;
    margin-bottom: 10px;
  }

  .card-title {
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .card-desc {
    font-size: 12px;
    line-height: 1.6;
    opacity: .7;
  }

  /* Hero */
  .card-hero {
    grid-column: 1 / -1;
    background: #1a1a18;
    color: #f2f0eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .card-hero .card-eyebrow { color: rgba(242,240,235,.4); }
  .arrow {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: rgba(255,255,255,.6);
    flex-shrink: 0;
    transition: background .2s;
  }
  .card-hero:hover .arrow { background: rgba(255,255,255,.08); }

  /* Green */
  .card-green {
    background: #c5f0da;
  }
  .card-green .card-eyebrow { color: #1a6640; }
  .card-green .card-title { color: #0d3320; }
  .card-green .card-desc { color: #2a7a50; }

  /* Yellow */
  .card-yellow {
    background: #f5e98a;
  }
  .card-yellow .card-eyebrow { color: #7a6a10; }
  .card-yellow .card-title { color: #3d3408; }
  .card-yellow .card-desc { color: #6b5c10; }

  /* SNS */
  .card-sns {
    grid-column: 1 / -1;
    background: #fff;
    display: flex;
    padding: 0;
    overflow: hidden;
    cursor: default;
  }
  .card-sns:hover { transform: none; box-shadow: none; }

  .sns-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 18px 8px;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid #f0ede8;
    transition: background .2s;
  }
  .sns-item:last-child { border-right: none; }
  .sns-item:hover { background: #f8f6f0; }

  .sns-name {
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #1a1a18;
  }
  .sns-desc {
    font-size: 10px;
    color: #aaa;
  }

  /* Skills */
  .card-skills {
    grid-column: 1 / -1;
    background: #edeae3;
    cursor: default;
  }
  .card-skills:hover { transform: none; box-shadow: none; }
  .card-skills .card-eyebrow { color: #888; }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .skill-tag {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    background: #fff;
    border: 1px solid #ddd;
    color: #444;
    padding: 4px 12px;
    border-radius: 100px;
  }

  /* FOOTER */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    font-size: 12px;
    color: #aaa;
    animation: fadeUp .6s .3s ease both;
  }

  footer a {
    color: #888;
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    transition: color .2s;
  }
  footer a:hover { color: #1a1a18; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .bento { grid-template-columns: 1fr; }
    .card-hero { flex-direction: column; align-items: flex-start; }
    .sns-item { padding: 14px 4px; }
  }
</style>