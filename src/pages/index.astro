---
import { getCollection } from "astro:content";

const allWorks = await getCollection("blog");
const sortedWorks = allWorks.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const cardColors = ["hero", "green", "yellow"];
const works = sortedWorks.map((post, index) => {
  let shortDesc = post.data.technologies.join(" / ");
  
  if (post.id.includes("pad-automation")) {
    shortDesc = "手作業を自動化し、工数を大幅削減したPADフロー構成。";
  } else if (post.id.includes("restaurant-app")) {
    shortDesc = "複数条件検索を備えた、実用的な飲食店管理Webアプリ。";
  }

  return {
    id: post.id,
    category: post.data.category,
    title: post.data.title,
    desc: shortDesc,
    url: `${import.meta.env.BASE_URL}/blog/${post.id}`,
    color: cardColors[index % cardColors.length],
  };
});

const sns = [
  { name: "X", desc: "日々の発信", url: "https://x.com/kou_gi_io" },
  { name: "Instagram", desc: "ビジュアル", url: "https://www.instagram.com/kou_gi_io/" },
  { name: "Threads", desc: "日常のつぶやき", url: "https://www.threads.com/@kou_gi_io" },
  { name: "TikTok", desc: "動画コンテンツ", url: "https://www.tiktok.com/@kou_gi_io" },
  { name: "Note", desc: "記事・技術ログ", url: "https://note.com/kou_gi_io" },
  { name: "LINE", desc: "自作スタンプ", url: "https://store.line.me/stickershop/author/6020446/ja" },
  { name: "GitHub", desc: "コードと実績", url: "https://github.com/kou-gin" },
];

const getIconSvg = (name) => {
  switch (name) {
    case 'X':
      // X icon (simple-icons)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>`;
    case 'Instagram':
      // Instagram icon (lucide)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`;
    case 'Threads':
      // Threads using @ symbol (Lucide AtSign)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"/></svg>`;
    case 'TikTok':
      // TikTok icon (simple-icons)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>`;
    case 'Note':
      // Note icon (Lucide PenTool format as fallback log icon)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`;
    case 'LINE':
      // LINE icon (Lucide MessageCircle but with LINE's exact green color)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#06C755" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>`;
    case 'GitHub':
      // GitHub icon (Lucide Github)
      return `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`;
    default:
      return '';
  }
};

const skills = ["Python", "Java", "JavaScript", "Power Automate Desktop", "Unity", "GitHub", "VSCode"];
---

<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Portfolio — KOU</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;800&family=Space+Mono&family=Noto+Sans+JP:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <div class="bg"></div>

  <main>

    <!-- HEADER -->
    <header>
      <div class="header-left">
        <span class="badge">ENGINEER & CREATOR</span>
        <h1>KOU / IT Automation & Create</h1>
        <p class="tagline">ITサポート20年 → Python / PAD<br/>技術と成果で価値を出す</p>
      </div>
      <div class="status">
        <span class="dot"></span>
        <span>Available</span>
      </div>
    </header>

    <!-- BENTO WORKS -->
    <section class="bento">

      {works.map((work) => (
        <a href={work.url} class={`card card-${work.color}`}>
          {work.color === "hero" ? (
            <div>
              <span class="card-eyebrow">{work.category}</span>
              <h2 class="card-title">{work.title}</h2>
              <p class="card-desc">{work.desc}</p>
            </div>
          ) : (
            <>
              <span class="card-eyebrow">{work.category}</span>
              <h2 class="card-title">{work.title}</h2>
              <p class="card-desc">{work.desc}</p>
            </>
          )}
          {work.color === "hero" && <span class="arrow">→</span>}
        </a>
      ))}

      <!-- SNS Card -->
      <div class="card card-sns">
        {sns.map(s => (
          <a href={s.url} class="sns-item" target="_blank">
            {getIconSvg(s.name) && (
              <span class="sns-icon" set:html={getIconSvg(s.name)}></span>
            )}
            <span class="sns-name">{s.name}</span>
            <span class="sns-desc">{s.desc}</span>
          </a>
        ))}
      </div>

      <!-- Skills Card -->
      <div class="card card-skills">
        <span class="card-eyebrow">SKILLS</span>
        <div class="skill-tags">
          {skills.map(s => <span class="skill-tag">{s}</span>)}
        </div>
      </div>

    </section>

    <footer>
      <span>© 2026 KOU</span>
      <a href="https://github.com/YOUR-USERNAME" target="_blank">GitHub →</a>
    </footer>

  </main>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Noto Sans JP', sans-serif;
    background: #f2f0eb;
    color: #1a1a18;
    min-height: 100vh;
  }

  /* 背景テクスチャ */
  .bg {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 48px 24px 40px;
  }

  /* HEADER */
  header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 36px;
    animation: fadeUp .6s ease both;
  }

  .badge {
    display: inline-block;
    background: #1a1a18;
    color: #f2f0eb;
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: 3px 9px;
    margin-bottom: 12px;
  }

  h1 {
  /* 'Syne' を外し、標準的で美しい 'Inter' や 'sans-serif' を指定 */
  font-family: 'Inter', 'Noto Sans JP', sans-serif; 
  
  /* 横長感を消すため、文字の間隔を「詰め」から「わずかに広め」に（0.02em?0.05em） */
  letter-spacing: 0.02em; 
  
  /* 文字の太さを 800(極太) から 700(太字) にしてスッキリさせる */
  font-weight: 700;
  
  font-size: clamp(32px, 6vw, 48px);
  line-height: 1.1;
  color: #1a1a18;
  margin-bottom: 12px;
  
  /* もし文字が横に引き伸ばされている設定(transform)があれば無効化 */
  transform: none; 
}

  .tagline {
    font-size: 13px;
    line-height: 1.7;
    color: #666;
    font-weight: 300;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: #666;
    white-space: nowrap;
    margin-top: 6px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2eb87c;
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(46,184,124,.4); }
    50% { box-shadow: 0 0 0 6px rgba(46,184,124,0); }
  }

  /* BENTO */
  .bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    animation: fadeUp .6s .15s ease both;
  }

  /* カード共通 */
  .card {
    border-radius: 18px;
    padding: 24px 22px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform .25s cubic-bezier(.4,0,.2,1), box-shadow .25s cubic-bezier(.4,0,.2,1);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 48px rgba(0,0,0,.1);
  }

  .card-eyebrow {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: .15em;
    margin-bottom: 10px;
  }

  .card-title {
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 18px;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 6px;
  }

  .card-desc {
    font-size: 12px;
    line-height: 1.6;
    opacity: .7;
  }

  /* Hero */
  .card-hero {
    background: #1a1a18;
    color: #f2f0eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .card-hero .card-title {
    font-size: clamp(14px, 4vw, 18px);
  }
  .card-hero .card-eyebrow { color: rgba(242,240,235,.4); }
  .arrow {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    color: rgba(255,255,255,.6);
    flex-shrink: 0;
    transition: background .2s;
  }
  .card-hero:hover .arrow { background: rgba(255,255,255,.08); }

  /* Green */
  .card-green {
    background: #c5f0da;
  }
  .card-green .card-eyebrow { color: #1a6640; }
  .card-green .card-title { 
    color: #0d3320; 
    font-size: clamp(13px, 3.5vw, 18px);
    white-space: nowrap;
    letter-spacing: -0.02em;
  }
  .card-green .card-desc { color: #2a7a50; }

  /* Yellow */
  .card-yellow {
    background: #f5e98a;
  }
  .card-yellow .card-eyebrow { color: #7a6a10; }
  .card-yellow .card-title { color: #3d3408; }
  .card-yellow .card-desc { color: #6b5c10; }

  /* SNS */
  .card-sns {
    grid-column: 1 / -1;
    background: #fff;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    padding: 0;
    overflow: hidden;
    cursor: default;
  }
  .card-sns:hover { transform: none; box-shadow: none; }

  .sns-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    padding: 18px 8px;
    text-decoration: none;
    color: inherit;
    border-right: 1px solid #f0ede8;
    transition: background .2s;
  }
  .sns-item:nth-child(7n) { border-right: none; }
  .sns-item:hover { background: #f8f6f0; }

  .sns-icon {
    width: 20px;
    height: 20px;
    margin-bottom: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a18;
  }
  .sns-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .sns-name {
    font-family: 'Inter', 'Noto Sans JP', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #1a1a18;
  }
  .sns-desc {
    font-size: 10px;
    color: #aaa;
  }

  /* Skills */
  .card-skills {
    grid-column: 1 / -1;
    background: #edeae3;
    cursor: default;
  }
  .card-skills:hover { transform: none; box-shadow: none; }
  .card-skills .card-eyebrow { color: #888; }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .skill-tag {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    background: #fff;
    border: 1px solid #ddd;
    color: #444;
    padding: 4px 12px;
    border-radius: 100px;
  }

  /* FOOTER */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 32px;
    font-size: 12px;
    color: #aaa;
    animation: fadeUp .6s .3s ease both;
  }

  footer a {
    color: #888;
    text-decoration: none;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    transition: color .2s;
  }
  footer a:hover { color: #1a1a18; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .bento { grid-template-columns: 1fr; }
    .card-hero { flex-direction: column; align-items: flex-start; }
    .card-sns { 
      display: flex; 
      flex-wrap: wrap; 
      justify-content: center; 
    }
    .sns-item { 
      width: calc(100% / 3);
      padding: 14px 4px;
      border-bottom: 1px solid #f0ede8;
    }
    .sns-item:nth-child(1n) { border-right: 1px solid #f0ede8; }
    .sns-item:nth-child(3n) { border-right: none; }
    .sns-item:last-child { 
      border-bottom: none; 
      border-right: none;
    }
  }
</style>